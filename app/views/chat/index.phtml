<main class="chat-layout">
    <aside class="sidebar">
        <h2>Salons</h2>

        <form method="post" action="index.php?route=create-salon" class="new-salon-form">
            <input type="text" name="name" placeholder="Nouveau salon" required>
            <button type="submit">Créer</button>
        </form>

        <ul>
            <?php foreach ($salons as $salon): ?>
                <li class="<?= ($activeSalon && $activeSalon->getId() === $salon->getId()) ? 'active' : ''; ?>">
                    <a href="index.php?route=salon&id=<?= $salon->getId(); ?>">
                        # <?= htmlspecialchars($salon->getName(), ENT_QUOTES, 'UTF-8'); ?>
                    </a>
                </li>
            <?php endforeach; ?>
        </ul>
    </aside>

    <section class="messages-zone">
        <?php if (!$activeSalon): ?>
            <p>Crée un salon pour commencer.</p>
        <?php else: ?>
            <h1># <?= htmlspecialchars($activeSalon->getName(), ENT_QUOTES, 'UTF-8'); ?></h1>

            <div class="messages-list">
                <?php foreach ($messages as $message): ?>
                    <article class="message <?= $message->isPinned() ? 'pinned' : ''; ?>">
                        <p><?= nl2br(htmlspecialchars($message->getContent(), ENT_QUOTES, 'UTF-8')); ?></p>
                        <div class="meta">
                            <small><?= htmlspecialchars($message->getCreatedAt(), ENT_QUOTES, 'UTF-8'); ?></small>
                            <form method="post" action="index.php?route=pin-message">
                                <input type="hidden" name="salon_id" value="<?= $activeSalon->getId(); ?>">
                                <input type="hidden" name="message_id" value="<?= $message->getId(); ?>">
                                <button type="submit">Épingler</button>
                            </form>
                        </div>
                    </article>
                <?php endforeach; ?>
            </div>

            <form method="post" action="index.php?route=send-message" class="new-message-form">
                <input type="hidden" name="salon_id" value="<?= $activeSalon->getId(); ?>">
                <textarea name="content" placeholder="Ton message anonyme..." required></textarea>
                <button type="submit">Envoyer</button>
            </form>
        <?php endif; ?>
    </section>
</main>
